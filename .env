# Reinicia "npm run dev" si cambias algo aquí.
#
# Vite solo expone variables que empiezan por VITE_.
# URL del mini backend, SIN barra final:

VITE_CONTACT_API_URL=http://localhost:3001

# Producción: descomenta la siguiente línea y pon la URL real del API.
# (en local deja solo la de arriba, o comenta una de las dos)
# VITE_CONTACT_API_URL=https://api.tudominio.com
